{
  "collectionName": "components_shared_video_hero_sections",
  "info": {
    "displayName": "Video Hero Section",
    "description": "Reusable video hero configuration for marketing pages"
  },
  "options": {},
  "attributes": {
    "firstPart": {
      "type": "string",
      "required": true
    },
    "secondPart": {
      "type": "string"
    },
    "video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files",
        "videos"
      ]
    },
    "isGoogleDrive": {
      "type": "boolean",
      "default": false
    },
    "overlayOpacity": {
      "type": "integer",
      "default": 20,
      "min": 0,
      "max": 100
    },
    "strokeColor": {
      "type": "string",
      "default": "#000000"
    },
    "fillColor": {
      "type": "string",
      "default": "#FEF991"
    },
    "textColor": {
      "type": "string",
      "default": "#FFFFFF"
    }
  }
}
