{
  "kind": "collectionType",
  "collectionName": "designers",
  "info": {
    "singularName": "designer",
    "pluralName": "designers",
    "displayName": "Designer",
    "description": "Designer/Artist profile and portfolio"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "seo": {
      "type": "component",
      "required": false,
      "component": "shared.seo"
    },
    "hero": {
      "type": "component",
      "component": "experience.hero",
      "required": false
    },
    "detail_rows": {
      "type": "component",
      "repeatable": true,
      "component": "project.detail-row",
      "required": false
    },
    "gallery": {
      "type": "component",
      "component": "project.media-gallery",
      "required": false
    },
    "listingImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
