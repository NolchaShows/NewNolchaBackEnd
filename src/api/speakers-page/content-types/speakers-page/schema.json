{
  "kind": "collectionType",
  "collectionName": "speakers_pages",
  "info": {
    "singularName": "speakers-page",
    "pluralName": "speakers-pages",
    "displayName": "Speakers",
    "description": "Structured speakers page rendered by the Next.js route /speakers."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "required": false
    },
    "hero": {
      "type": "component",
      "component": "experience.hero",
      "required": false
    },
    "shared_speaker_section": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::shared-speaker-section.shared-speaker-section",
      "required": false
    },
    "gallery": {
      "type": "component",
      "component": "project.media-gallery",
      "required": false
    }
  }
}
